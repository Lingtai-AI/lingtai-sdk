{
  "mcp": {
    "nokv-workbench": {
      "type": "stdio",
      "command": "/path/to/nokv",
      "args": [
        "--server-bind",
        "127.0.0.1:7777",
        "--object-backend",
        "rustfs",
        "--s3-bucket",
        "nokv-lingtai-workbench",
        "mcp",
        "--profile",
        "workbench",
        "--workbench-root",
        "/agents/{agent_id}/wb"
      ]
    }
  }
}
